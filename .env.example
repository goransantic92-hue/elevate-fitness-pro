VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: serve homepage testimonial videos from /public while uploading to Storage (dev only).
# Remove after running: npm run upload:testimonials
# VITE_TESTIMONIAL_VIDEO_SOURCE=local

# Production site URL — set on Vercel so auth confirmation emails redirect to the live domain (not localhost).
# Must match entries in Supabase → Authentication → URL Configuration → Site URL + Redirect URLs, including:
#   https://busystrong90.com
#   https://busystrong90.com/login
#   https://busystrong90.com/auth/callback   (email confirmation / PKCE return — required after signup)
# Wildcard is ok: https://busystrong90.com/**
# VITE_SITE_URL=https://busystrong90.com

# Better inbox placement for Supabase auth emails: Dashboard → Project Settings → Auth → SMTP (custom SMTP e.g. Resend + verified domain), SPF/DKIM on your domain.

# Coaching apply form → Resend (set in Vercel project env, not VITE_* — server-only)
# RESEND_API_KEY=re_xxxx
# COACHING_NOTIFY_EMAIL=info@ptmilosilic.com
# COACHING_FROM_EMAIL=Coach Milos <info@ptmilosilic.com>
# CALENDLY_CONSULT_URL=https://calendly.com/...

# Stripe (server-only — set in Vercel). SUPABASE_* duplicate your project URL/keys for API routes (not exposed to browser).
# SITE_URL=https://busystrong90.com
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=same_as_VITE_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# STRIPE_SECRET_KEY=sk_live_...   # or sk_test_... for test mode
# STRIPE_WEBHOOK_SECRET=whsec_... # from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# STRIPE_NOTIFY_EMAIL=info@ptmilosilic.com
#
# Optional: server-created Checkout Session ( Pricing can use API instead of Payment Link — see create-checkout-session.ts )
# STRIPE_PRICE_ID=price_xxx
#
# --- Stripe Dashboard checklist (Payment Link flow, used by VITE_STRIPE_PAYMENT_LINK) ---
# 1) Payment Link → After payment → Success URL must include the session id so the app can confirm and unlock content:
#    https://YOUR_DOMAIN/dashboard?checkout=success&session_id={CHECKOUT_SESSION_ID}
# 2) Developers → Webhooks → Add endpoint: https://YOUR_DOMAIN/api/stripe/webhook
#    Events: checkout.session.completed
# 3) Same Stripe mode (test/live) for STRIPE_SECRET_KEY, webhook secret, and Payment Link.
# Webhook grants access + optional admin email; /dashboard success + verify-session grants access + toast for the buyer.

# Frontend payment link used by Pricing page button (must match the link in Stripe whose success URL you configured above).
# VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/aFa3cu1Ou1nu61mgSj3cc0b
