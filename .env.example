VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: canonical URL for email confirmation links (otherwise uses current browser origin)
# VITE_SITE_URL=https://your-app.vercel.app

# Coaching apply form → Resend (set in Vercel project env, not VITE_* — server-only)
# RESEND_API_KEY=re_xxxx
# COACHING_NOTIFY_EMAIL=info@ptmilosilic.com
# COACHING_FROM_EMAIL=Coach Milos <info@ptmilosilic.com>
# CALENDLY_CONSULT_URL=https://calendly.com/...

# Stripe (server-only — set in Vercel). SUPABASE_* duplicate your project URL/keys for API routes (not exposed to browser).
# SITE_URL=https://busystrong90.com
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=same_as_VITE_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_...
